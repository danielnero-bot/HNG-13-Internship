{
  "expo": {
    "name": "HNG",
    "slug": "HNG",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "hng",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.danielnerobot.HNG"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a4029df7-ce45-4dac-91ec-11e24b4be824"
      }
    },
    "owner": "danielnero-bot"
  }
}
