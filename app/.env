<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=Manrope:wght@700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "surface-container-highest": "#32353c",
                    "outline": "#8b919c",
                    "surface-container-lowest": "#0b0e14",
                    "on-primary-fixed": "#001d37",
                    "surface-bright": "#363940",
                    "on-error": "#690005",
                    "on-secondary-container": "#acbacc",
                    "surface-tint": "#9fcaff",
                    "tertiary": "#ffb86e",
                    "error": "#ffb4ab",
                    "surface-container": "#1d2026",
                    "on-secondary-fixed-variant": "#3b4857",
                    "primary-container": "#4894e2",
                    "on-surface-variant": "#c0c7d3",
                    "tertiary-fixed-dim": "#ffb86e",
                    "inverse-on-surface": "#2e3037",
                    "surface-container-low": "#191c22",
                    "primary-fixed-dim": "#9fcaff",
                    "tertiary-container": "#cd7f1b",
                    "surface-container-high": "#272a31",
                    "on-tertiary-fixed": "#2c1600",
                    "surface-variant": "#32353c",
                    "secondary-container": "#3d4a5a",
                    "surface": "#10131a",
                    "on-primary-fixed-variant": "#00497e",
                    "surface-dim": "#10131a",
                    "primary-fixed": "#d2e4ff",
                    "secondary": "#bac8da",
                    "inverse-surface": "#e1e2eb",
                    "on-secondary-fixed": "#0f1d2a",
                    "on-error-container": "#ffdad6",
                    "secondary-fixed": "#d6e4f7",
                    "inverse-primary": "#0061a5",
                    "on-tertiary": "#492900",
                    "outline-variant": "#414751",
                    "primary": "#9fcaff",
                    "on-background": "#e1e2eb",
                    "error-container": "#93000a",
                    "background": "#10131a",
                    "on-primary": "#003259",
                    "on-tertiary-container": "#402300",
                    "on-surface": "#e1e2eb",
                    "on-tertiary-fixed-variant": "#693c00",
                    "on-secondary": "#243240",
                    "tertiary-fixed": "#ffdcbd",
                    "secondary-fixed-dim": "#bac8da",
                    "on-primary-container": "#002b4e"
            },
            "borderRadius": {
                    "DEFAULT": "0.25rem",
                    "lg": "0.5rem",
                    "xl": "0.75rem",
                    "full": "9999px"
            },
            "fontFamily": {
                    "headline": ["Manrope"],
                    "body": ["Inter"],
                    "label": ["Inter"]
            }
          },
        },
      }
    </script>
<style>
        body {
            background-color: #10131a;
            color: #e1e2eb;
            font-family: 'Inter', sans-serif;
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .monolith-gradient {
            background: linear-gradient(180deg, #10131a 0%, #0b0e14 100%);
        }
        .card-shadow {
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="monolith-gradient min-h-screen pb-32">
<!-- TopAppBar -->
<header class="bg-[#10131a] dark:bg-[#10131a] docked full-width top-0 flex justify-between items-center w-full px-6 h-16 sticky z-40">
<div class="flex items-center gap-4">
<span class="material-symbols-outlined text-slate-400 cursor-pointer active:scale-95 duration-200">menu</span>
<h1 class="font-['Manrope'] font-bold tracking-tight text-xl font-extrabold text-blue-400 tracking-tighter">Smart Toolkit</h1>
</div>
<div class="flex items-center">
<span class="material-symbols-outlined text-slate-400 cursor-pointer hover:opacity-80 transition-opacity active:scale-95 duration-200">notifications</span>
</div>
</header>
<main class="px-6 pt-8 max-w-2xl mx-auto">
<!-- Hero Section -->
<section class="mb-10">
<h2 class="font-headline text-[1.75rem] font-bold text-on-surface mb-1"></h2>
<p class="font-body text-on-surface-variant opacity-70"></p>
</section>
<!-- Utility Cards Grid -->
<div class="space-y-6">
<!-- Length Converter Card -->
<div class="group relative bg-surface-container rounded-[20px] p-6 card-shadow transition-all duration-300 hover:bg-surface-container-high overflow-hidden">
<div class="absolute top-0 left-0 w-1 h-full bg-primary opacity-0 group-hover:opacity-100 transition-opacity"></div>
<div class="flex items-start gap-5">
<div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
<span class="material-symbols-outlined text-3xl">straighten</span>
</div>
<div class="flex-1">
<h3 class="font-headline text-lg font-bold text-on-surface mb-1">Length Converter</h3>
<p class="font-body text-sm text-on-surface-variant leading-relaxed"></p>
<div class="mt-4 flex items-center gap-2 text-primary text-xs font-bold uppercase tracking-widest">
<span>Open Tool</span>
<span class="material-symbols-outlined text-sm">arrow_forward</span>
</div>
</div>
</div>
</div>
<!-- Temperature Converter Card -->
<div class="group relative bg-surface-container rounded-[20px] p-6 card-shadow transition-all duration-300 hover:bg-surface-container-high overflow-hidden">
<div class="absolute top-0 left-0 w-1 h-full bg-primary opacity-0 group-hover:opacity-100 transition-opacity"></div>
<div class="flex items-start gap-5">
<div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
<span class="material-symbols-outlined text-3xl">device_thermostat</span>
</div>
<div class="flex-1">
<h3 class="font-headline text-lg font-bold text-on-surface mb-1">Temperature Converter</h3>
<p class="font-body text-sm text-on-surface-variant leading-relaxed">Instant Celsius to Fahrenheit conversions for weather or technical data.</p>
<div class="mt-4 flex items-center gap-2 text-primary text-xs font-bold uppercase tracking-widest">
<span>Open Tool</span>
<span class="material-symbols-outlined text-sm">arrow_forward</span>
</div>
</div>
</div>
</div>
<!-- Currency Converter Card -->
<div class="group relative bg-surface-container rounded-[20px] p-6 card-shadow transition-all duration-300 hover:bg-surface-container-high overflow-hidden">
<div class="absolute top-0 left-0 w-1 h-full bg-primary opacity-0 group-hover:opacity-100 transition-opacity"></div>
<div class="flex items-start gap-5">
<div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary">
<span class="material-symbols-outlined text-3xl">payments</span>
</div>
<div class="flex-1">
<h3 class="font-headline text-lg font-bold text-on-surface mb-1">Currency Converter</h3>
<p class="font-body text-sm text-on-surface-variant leading-relaxed">Real-time exchange rates for global markets and travel planning.</p>
<div class="mt-4 flex items-center gap-2 text-primary text-xs font-bold uppercase tracking-widest">
<span>Open Tool</span>
<span class="material-symbols-outlined text-sm">arrow_forward</span>
</div>
</div>
</div>
</div>
</div>
<!-- Featured Visual Decoration -->
<div class="mt-12 rounded-[24px] overflow-hidden relative h-48 bg-surface-container-lowest flex items-center justify-center">
<div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-transparent"></div>
<div class="relative z-10 text-center px-6">
<p class="font-label text-primary mb-2 tracking-[0.2em] uppercase">Coming Soon</p>
<h4 class="font-headline text-xl font-bold">Scientific Calculator Pro</h4>
</div>
<div class="absolute -right-10 -bottom-10 w-40 h-40 bg-primary/5 rounded-full blur-3xl"></div>
</div>
</main>
<!-- BottomNavBar -->
<nav class="fixed bottom-0 left-0 w-full z-50 flex justify-around items-center px-4 pb-6 pt-3 bg-[#1d2026]/60 backdrop-blur-xl fixed bottom-0 w-full rounded-t-[1.5rem] shadow-[0_-20px_40px_rgba(0,0,0,0.12)]">
<!-- Home Active -->
<a class="flex flex-col items-center justify-center text-blue-400 bg-blue-400/10 rounded-2xl py-1 px-4 active:scale-90 transition-transform" href="#">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">home</span>
<span class="font-['Inter'] text-[11px] font-medium tracking-wide uppercase mt-1">Home</span>
</a>
<!-- History -->
<a class="flex flex-col items-center justify-center text-slate-500 hover:text-blue-300 active:scale-90 transition-transform" href="#">
<span class="material-symbols-outlined">history</span>
<span class="font-['Inter'] text-[11px] font-medium tracking-wide uppercase mt-1">History</span>
</a>
<!-- Settings -->
<a class="flex flex-col items-center justify-center text-slate-500 hover:text-blue-300 active:scale-90 transition-transform" href="#">
<span class="material-symbols-outlined">settings</span>
<span class="font-['Inter'] text-[11px] font-medium tracking-wide uppercase mt-1">Settings</span>
</a>
</nav>
</body></html>